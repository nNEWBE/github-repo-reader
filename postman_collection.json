{
  "info": {
    "_postman_id": "4b6e5892-d98c-489e-a8f8-b3d5b248a318",
    "name": "GitHub Repo Reader API",
    "description": "Professional Postman collection for testing the Spring Boot GitHub Repo Reader API endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Read Contributions",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response should be a success\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.eql(true);",
              "    pm.expect(jsonData.message).to.eql(\"Read successful\");",
              "});",
              "",
              "pm.test(\"Data should be an array of repositories\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.be.an('array');",
              "    if(jsonData.data.length > 0) {",
              "        pm.expect(jsonData.data[0]).to.have.property('name');",
              "        pm.expect(jsonData.data[0]).to.have.property('url');",
              "        pm.expect(jsonData.data[0]).to.have.property('contribution');",
              "        pm.expect(jsonData.data[0].contribution).to.be.an('array');",
              "    }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/v1/read_contributions",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "v1",
            "read_contributions"
          ]
        },
        "description": "Returns the contributors of the tracked GitHub repositories."
      },
      "response": []
    },
